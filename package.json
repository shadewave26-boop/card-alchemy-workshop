{
  "name": "card-alchemy-workshop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "カード錬成工房 - スマホで遊ぶTCG風カード共作パーティーゲーム",
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "cross-env NODE_ENV=development node server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "icons": "node scripts/generate-icons.mjs",
    "smoke": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.6.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "vite": "^5.4.19"
  }
}
