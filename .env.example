# ===== サーバー基本設定 =====
# ホスティングサービスから渡されるポート（未設定時は3000）
PORT=3000
# production / development
NODE_ENV=production
# 公開URL（任意。参加URLは基本的にクライアントが自オリジンから生成する）
PUBLIC_BASE_URL=

# ===== ルーム状態の保存 =====
# Redis接続先（例: redis://default:password@host:6379）
# 未設定の場合はメモリ管理へフォールバック（サーバー再起動で進行中ゲームは消える）
REDIS_URL=
# ルームの自動破棄までの秒数（最終アクセスから。既定7200 = 2時間）
ROOM_TTL_SECONDS=7200

# ===== ゲーム設定 =====
# 最大参加人数（既定4。5以上を指定しても4に丸められる）
MAX_PLAYERS=4
# テキスト工程の制限時間（秒）。開発時は 5 などに短縮すると確認しやすい
TEXT_ROUND_SECONDS=30
# イラスト工程の制限時間（秒）。開発時は 15 などに短縮すると確認しやすい
DRAWING_ROUND_SECONDS=120
# イラストPNG dataURLの最大サイズ（バイト）
MAX_IMAGE_BYTES=1500000
# カード名の前半と後半の間に空白を挿入するか（1で挿入）
NAME_JOIN_SPACE=0

# ===== 開発専用（NODE_ENV=production では無効） =====
# カード種別を固定する: normal / effect / fusion
FORCE_CARD_TYPE=
